{# Strava API import mode has been removed: fields are never disabled here anymore. #}
{% set disabled = false %}
<div>
    <label for="{{ for }}" class="flex items-center gap-1.5">
        {{ label }}
        {% if disabled %}{% include 'html/admin/component/strava-imported-badge.html.twig' %}{% endif %}
    </label>
    {% block control %}{% endblock %}
    {% if disabled %}<input type="hidden" name="{{ name }}" value="{{ value }}">{% endif %}
</div>
