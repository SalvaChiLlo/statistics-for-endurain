# ENDURAIN_URL must be a valid URL: unlike the Strava env vars above, EndurainUrl
# extends the strict Url value object, which validates its value eagerly the
# moment the Endurain service is constructed.
ENDURAIN_URL=https://endurain.example.com
ENDURAIN_USERNAME=replace-me
ENDURAIN_PASSWORD=replace-me